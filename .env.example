# ============================================================
# DB Learning Lab — Variables de entorno / Environment variables
# ============================================================
# Copiar este archivo a .env y ajustar los valores antes de
# ejecutar el entorno por primera vez.
# Copy this file to .env and adjust the values before running
# the environment for the first time.
# ============================================================

# Usuario para todas las bases de datos / User for all databases
DB_USER=labuser

# Contraseña compartida / Shared password
# IMPORTANTE: cambia esto antes de exponer el entorno en una red
# IMPORTANT: change this before exposing the environment on a network
DB_PASSWORD=labpass123

# Nombre de la base de datos inicial / Initial database name
DB_NAME=labdb
